import random
import time
from database import criar_base_dados, guardar_descontaminacao, ver_historico_descontaminacao

def algoritmo_whiteley(valor_atp):
    """
    Simulação do Algoritmo de Whiteley para validação de limpeza.
    Target de conformidade > 71%[cite: 567].
    """
    if valor_atp < 100:
        return "APROVADO (Limpeza Eficaz)"
    else:
        return "FALHA (Bioburden Detetado)"

print("Simulador de Descontaminação Avançado (Requisitos 4.2)")
print("--" * 40)

criar_base_dados()

# Requisitos 4.2: Validação de Diluição e Tempo de Imersão [cite: 547]
detergente_diluicao_ok = 1 # Simulação de validação de rácio de diluição
tempo_imersao = random.randint(15, 30) # Tempo em minutos

fases = [
    {"nome": "Pré-lavagem", "temp_alvo": 30.0, "pressao_alvo": 1.5, "duracao": 2},
    {"nome": "Lavagem Enzimática", "temp_alvo": 45.0, "pressao_alvo": 2.5, "duracao": 3},
    {"nome": "Desinfeção Térmica", "temp_alvo": 90.0, "pressao_alvo": 1.0, "duracao": 4}
]

lote_id = f"LOTE-{random.randint(1000, 9999)}"
temp_maxima = 0.0
pressao_acumulada = 0.0

for fase in fases:
    print(f"\n>> Fase: {fase['nome']}")
    temp_real = fase["temp_alvo"] + random.uniform(-1.0, 1.0)
    pressao_real = fase["pressao_alvo"] + random.uniform(-0.1, 0.1)
    
    print(f"   Temperatura : {temp_real:.1f} °C")
    if temp_real > temp_maxima: temp_maxima = temp_real
    pressao_acumulada += pressao_real
    time.sleep(1)

# Validação Científica após limpeza 
valor_atp = random.uniform(10, 150) # Unidades Relativas de Luz (RLU)
resultado_limpeza = algoritmo_whiteley(valor_atp)

print("\n" + "=" * 40)
print(f"RESULTADO DO LOTE: {lote_id}")
print(f"Diluição Detergente: {'Conforme' if detergente_diluicao_ok else 'Não Conforme'}")
print(f"Tempo Imersão: {tempo_imersao} min")
print(f"Teste ATP: {valor_atp:.1f} RLU -> {resultado_limpeza}")
print("=" * 40)

# Persistência com novos requisitos
guardar_descontaminacao(
    lote_id, 
    temp_maxima, 
    pressao_acumulada / len(fases), 
    detergente_diluicao_ok, 
    tempo_imersao, 
    valor_atp, 
    resultado_limpeza
)

ver_historico_descontaminacao()